{
  "name": "modern-democracy-server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "dev:worker": "tsx src/worker.ts",
    "build": "tsc -p tsconfig.json && cp src/schema.sql dist/schema.sql",
    "start": "node dist/index.js",
    "start:worker": "node dist/worker.js",
    "seed:demo": "tsx src/seed-demo.ts",
    "lint": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.1",
    "fastify": "^5.2.0",
    "postgres": "^3.4.5",
    "unpdf": "^1.6.2"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "tsx": "^4.19.2",
    "typescript": "^5.8.3"
  }
}
